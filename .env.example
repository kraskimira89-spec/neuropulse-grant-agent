# Скопируйте в .env и заполните значения.
# .env не коммитится в Git.

# Yandex AI Studio (для подключения по API)
# YANDEX_API_KEY=ваш_API_ключ
# YANDEX_FOLDER_ID=ваш_идентификатор_каталога  (каталог, обычно b1g...; не путать с agent_id)
# YANDEX_AI_AGENT_ID=идентификатор_агента  (идентификатор агента из Agent Atelier; иначе используется model)
# YANDEX_AI_BASE_URL=  (опционально; по умолчанию https://ai.api.cloud.yandex.net/v1)
# YANDEX_VECTOR_STORE_ID=идентификатор_поискового_индекса

# Яндекс Календарь (CalDAV) — блок «Ближайшие сроки» в дашборде
# Пароль приложения: https://id.yandex.ru/security/app-passwords → тип «Календарь»
# YANDEX_CALENDAR_USER=ваш_email@yandex.ru
# YANDEX_CALENDAR_APP_PASSWORD=пароль_приложения
# YANDEX_CALENDAR_URL=   (опционально: URL календаря из Экспорт в calendar.yandex.ru)
# --- Календарь «Нейропульс» (блок на дашборде) ---
# В дашборде используйте ТОЛЬКО публичный адрес (без private_token). Секретный адрес и private_token
# храните только у себя (для iCal/подписок) и не добавляйте их в EMBED_URL.
# CalDAV URL календаря «Нейропульс» (обязательно caldav.yandex.ru; из Экспорт в calendar.yandex.ru):
# YANDEX_CALENDAR_NEUROPULSE_URL=https://caldav.yandex.ru/calendars/ваш_email/events-ID_календаря/
# Публичный адрес из Экспорт → «Код для вставки на сайт» (src из iframe, без private_token):
# YANDEX_CALENDAR_NEUROPULSE_EMBED_URL=https://calendar.yandex.ru/embed/week?&layer_ids=36659807&tz_id=Asia/Yekaterinburg&layer_names=Нейропульс

# Уведомления по гранту (письма за 3 дня до события)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=пароль_или_пароль_приложения
# NOTIFICATION_EMAIL=получатель@example.com

# Яндекс.Диск — загрузка сгенерированных документов (OAuth-токен: oauth.yandex.ru, права disk.read, disk.write)
# YANDEX_DISK_ACCESS_TOKEN=ваш_oauth_токен
# YANDEX_DISK_UPLOAD_FOLDER=Файлы/ЦИП/ПРОЕКТЫ/2025 Грант Губернатора/Документы контролера

# Яндекс Файлы (пароль приложения, для иных интеграций)
# YANDEX_FILES_APP_PASSWORD=пароль_приложения

# Яндекс Контакты — Пароли приложений → Контакты
# YANDEX_CONTACTS_APP_PASSWORD=пароль_приложения

# Яндекс Навигатор — Пароли приложений → Навигатор
# YANDEX_NAVIGATOR_APP_PASSWORD=пароль_приложения

# Яндекс Карты (опционально: для геокодера; ссылка «Открыть в Картах» в дашборде работает без ключа)
# YANDEX_MAPS_API_KEY=ключ_из_developer.yandex.ru

# Агент Парсер (Telegram + публичные папки Яндекс.Диска → Vector Store)
# Получить API_ID и API_HASH: https://my.telegram.org/apps
# TELEGRAM_API_ID=ваш_api_id
# TELEGRAM_API_HASH=ваш_api_hash
# TELEGRAM_PHONE=+7... (для входа в аккаунт при первом запуске)
# Список каналов и ссылок на папки Диска — в config/config.json, секция parser.

# Другие API (если нужны)
# API_BASE_URL=https://api.example.com
# API_KEY=your-api-key
