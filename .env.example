# Скопируйте в .env и заполните значения.
# .env не коммитится в Git.

# Yandex AI Studio (для подключения по API)
# YANDEX_API_KEY=ваш_API_ключ
# YANDEX_FOLDER_ID=b1gp3rqkf5t6kqmqaf7c
# YANDEX_VECTOR_STORE_ID=идентификатор_поискового_индекса

# Яндекс Календарь (CalDAV) — блок «Ближайшие сроки» в дашборде
# Пароль приложения: https://id.yandex.ru/security/app-passwords → тип «Календарь»
# YANDEX_CALENDAR_USER=ваш_email@yandex.ru
# YANDEX_CALENDAR_APP_PASSWORD=пароль_приложения
# YANDEX_CALENDAR_URL=   (опционально: URL календаря из Экспорт в calendar.yandex.ru)

# Уведомления по гранту (письма за 3 дня до события)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=пароль_или_пароль_приложения
# NOTIFICATION_EMAIL=получатель@example.com

# Яндекс.Диск — загрузка сгенерированных документов (OAuth-токен: oauth.yandex.ru, права disk.read, disk.write)
# YANDEX_DISK_ACCESS_TOKEN=ваш_oauth_токен
# YANDEX_DISK_UPLOAD_FOLDER=Файлы/ЦИП/ПРОЕКТЫ/2025 Грант Губернатора/Документы контролера

# Яндекс Файлы (пароль приложения, для иных интеграций)
# YANDEX_FILES_APP_PASSWORD=пароль_приложения

# Яндекс Контакты — Пароли приложений → Контакты
# YANDEX_CONTACTS_APP_PASSWORD=пароль_приложения

# Яндекс Навигатор — Пароли приложений → Навигатор
# YANDEX_NAVIGATOR_APP_PASSWORD=пароль_приложения

# Яндекс Карты (опционально: для геокодера; ссылка «Открыть в Картах» в дашборде работает без ключа)
# YANDEX_MAPS_API_KEY=ключ_из_developer.yandex.ru

# Другие API (если нужны)
# API_BASE_URL=https://api.example.com
# API_KEY=your-api-key
